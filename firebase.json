{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "*.md",
      "firebase-debug.log"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**/*.@(css|js)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800" }]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|svg|webp|ico)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000" }]
      },
      {
        "source": "**/*.html",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
        ]
      }
    ],
    "redirects": [
      { "source": "/plans.html", "destination": "/protection-plans.html", "type": 301 },
      { "source": "/services/water-heaters.html", "destination": "/services/plumbing.html", "type": 301 },
      { "source": "/services/water-heaters", "destination": "/services/plumbing.html", "type": 301 }
    ],
    "errorPage": "404.html"
  }
}
